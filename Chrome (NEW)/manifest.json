{
    "manifest_version": 3,
    "name": "Domo Helper",
    "version": "1.1",
    "description": "Disables the Magic ETL and SQL ETL save button in Domo until a version description is entered.",
    "permissions": [
      "activeTab",
      "storage",
      "tabs",
      "scripting",
      "clipboardRead",
      "clipboardWrite",
      "debugger",
      "sidePanel",
      "webNavigation"
    ],
    "host_permissions": [
      "*://*.domo.com/datacenter/dataflows/*/graph",
      "*://*.domo.com/datacenter/dataflows/*/author",
      "*://*.domo.com/page/*"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_icon": {
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
      }
    },
    "side_panel": {
      "default_path": "side_panel.html"
    },
    "content_scripts": [
      {
        "matches": [
          "*://*.domo.com/datacenter/dataflows/*/graph",
          "*://*.domo.com/datacenter/dataflows/*/author",
          "*://*.domo.com/page/*"
        ],
        "js": [
          "jquery-3.7.1.min.js"
        ],
        "run_at": "document_start"
      },
      {
        "matches": [
          "*://*.domo.com/datacenter/dataflows/*/graph",
          "*://*.domo.com/datacenter/dataflows/*/author",
          "*://*.domo.com/page/*"
        ],
        "js": [
          "content/loader.js"
        ],
        "type": "module",
        "run_at": "document_idle"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": [
          "css/dh-graph-style.css",
          "css/dh-page-style.css",
          "css/dh-author-style.css",
          "content/loader.js",
          "content/content-main.js",
          "content/modules/*.js",
          "content/shared/*.js",
          "content/features/*.js",
          "clipboard-helper.js"
        ],
        "matches": [
          "*://*.domo.com/*"
        ]
      }
    ],
    "author": "Blueprint Coding",
    "homepage_url": "https://blueprintcoders.com/"
  }
  